{
  "name": "test-file-generator",
  "publisher": "tmslpm",
  "license": "MIT",
  "displayName": "Better Test File Generator",
  "description": "%extension.description%",
  "icon": "icon.png",
  "version": "0.0.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmslpm/vscode-test-file-generator"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "l10n": "./src/main/l10n/bundle.l10n.json",
  "contributes": {
    "commands": [
      {
        "command": "testFileGenerator.generate",
        "title": "%command.generate.title%",
        "category": "testing"
      },
      {
        "command": "testFileGenerator.goToCounterpart",
        "title": "%command.goToCounterpart.title%",
        "category": "testing"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "testFileGenerator.generate",
          "group": "testing",
          "when": "resourceScheme == file && !explorerResourceIsFolder"
        },
        {
          "command": "testFileGenerator.goToCounterpart",
          "group": "testing",
          "when": "resourceScheme == file && !explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "testFileGenerator.generate",
          "group": "testing",
          "when": "resourceScheme == file"
        },
        {
          "command": "testFileGenerator.goToCounterpart",
          "group": "testing",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "testFileGenerator.sourceRootPattern": {
          "type": "string",
          "default": "src",
          "description": "%config.sourceRootPattern.description%"
        },
        "testFileGenerator.testRootPattern": {
          "type": "string",
          "default": "test",
          "description": "%config.testRootPattern.description%"
        },
        "testFileGenerator.testSuffix": {
          "type": "string",
          "default": ".test",
          "description": "%config.testSuffix.description%"
        },
        "testFileGenerator.hardcorePatterns": {
          "type": "array",
          "default": [],
          "description": "%config.hardcorePatterns.description%"
        },
        "testFileGenerator.hardcoreTodoLines": {
          "type": "array",
          "default": [
            "",
            "TODO: Implement tests for this file {name}",
            "generated by Test File Generator",
            ""
          ],
          "description": "%config.hardcoreTodoLines.description%"
        }
      }
    },
    "snippets": [
      {
        "language": "typescript",
        "path": "./src/main/snippets/tfg-ts.code-snippets"
      },
      {
        "language": "typescript",
        "path": "./src/main/snippets/tfg-tsx.code-snippets"
      },
      {
        "language": "typescript",
        "path": "./src/main/snippets/tfg-mts.code-snippets"
      },
      {
        "language": "typescript",
        "path": "./src/main/snippets/tfg-cts.code-snippets"
      },
      {
        "language": "javascript",
        "path": "./src/main/snippets/tfg-js.code-snippets"
      },
      {
        "language": "javascript",
        "path": "./src/main/snippets/tfg-jsx.code-snippets"
      },
      {
        "language": "javascript",
        "path": "./src/main/snippets/tfg-mjs.code-snippets"
      },
      {
        "language": "javascript",
        "path": "./src/main/snippets/tfg-cjs.code-snippets"
      },
      {
        "language": "python",
        "path": "./src/main/snippets/tfg-py.code-snippets"
      },
      {
        "language": "go",
        "path": "./src/main/snippets/tfg-go.code-snippets"
      },
      {
        "language": "java",
        "path": "./src/main/snippets/tfg-java.code-snippets"
      },
      {
        "language": "csharp",
        "path": "./src/main/snippets/tfg-cs.code-snippets"
      },
      {
        "language": "rust",
        "path": "./src/main/snippets/tfg-rs.code-snippets"
      },
      {
        "language": "php",
        "path": "./src/main/snippets/tfg-php.code-snippets"
      },
      {
        "language": "ruby",
        "path": "./src/main/snippets/tfg-rb.code-snippets"
      },
      {
        "language": "swift",
        "path": "./src/main/snippets/tfg-swift.code-snippets"
      },
      {
        "language": "c",
        "path": "./src/main/snippets/tfg-c.code-snippets"
      },
      {
        "language": "cpp",
        "path": "./src/main/snippets/tfg-cpp.code-snippets"
      },
      {
        "language": "dart",
        "path": "./src/main/snippets/tfg-dart.code-snippets"
      },
      {
        "language": "lua",
        "path": "./src/main/snippets/tfg-lua.code-snippets"
      },
      {
        "language": "r",
        "path": "./src/main/snippets/tfg-r.code-snippets"
      },
      {
        "language": "julia",
        "path": "./src/main/snippets/tfg-jl.code-snippets"
      },
      {
        "language": "shellscript",
        "path": "./src/main/snippets/tfg-sh.code-snippets"
      },
      {
        "language": "powershell",
        "path": "./src/main/snippets/tfg-ps1.code-snippets"
      },
      {
        "language": "clojure",
        "path": "./src/main/snippets/tfg-clj.code-snippets"
      }
    ],
    "keybindings": [
      {
        "command": "testFileGenerator.goToCounterpart",
        "key": "alt+shift+t",
        "when": "editorFocus"
      }
    ]
  },
  "scripts": {
    "vscode:pack": "sh ./scripts/localize.sh copy && npx @vscode/vsce package && sh ./scripts/localize.sh clean",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "l18": "npx @vscode/l10n-dev export --outDir ./src/main/l10n ./src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/picomatch": "^4.0.2",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@vscode/l10n": "^0.0.18",
    "picomatch": "^4.0.3"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
