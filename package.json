{
  "name": "test-file-generator",
  "publisher": "tmslpm",
  "license":"MIT",
  "displayName": "test-file-generator",
  "description": "Generates test files mirroring the source directory structure, with automatic snippet injection and optional auto-generation on file creation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "testFileGenerator.generate",
        "title": "Generate Test File"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "testFileGenerator.generate",
          "group": "testing",
          "when": "resourceScheme == file && !explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "testFileGenerator.generate",
          "group": "testing",
          "when": "resourceScheme == file"
        }
      ]
    },
    "configuration": {
      "title": "Test File Generator",
      "properties": {
        "testFileGenerator.srcRoot": {
          "type": "string",
          "default": "src/main",
          "description": "Root directory of source files"
        },
        "testFileGenerator.testRoot": {
          "type": "string",
          "default": "src/test",
          "description": "Root directory of test files"
        },
        "testFileGenerator.testSuffix": {
          "type": "string",
          "default": ".test",
          "description": "Suffix appended before the extension for test files"
        },
        "testFileGenerator.snippetName": {
          "type": "string",
          "default": ""
        },
        "testFileGenerator.hardcoreMode": {
          "type": "boolean",
          "default": false
        },
        "testFileGenerator.hardcorePatterns": {
          "type": "array",
          "default": [
            "**/*.ts"
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/picomatch": "^4.0.2",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "picomatch": "^4.0.3"
  }
}
